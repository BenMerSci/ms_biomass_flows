@article{Duffy2002BioEco,
  title = {Biodiversity and Ecosystem Function: The Consumer Connection},
  shorttitle = {Biodiversity and Ecosystem Function},
  author = {Duffy, J. Emmett},
  year = {2002},
  journal = {Oikos},
  volume = {99},
