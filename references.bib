@article{Portalier2019MecPre,
  title = {The Mechanics of Predator--Prey Interactions: {{First}} Principles of Physics Predict Predator--Prey Size Ratios},
  shorttitle = {The Mechanics of Predator--Prey Interactions},
  author = {Portalier, S{\'e}bastien M. J. and Fussmann, Gregor F. and Loreau, Michel and Cherif, Mehdi},
  year = {2019},
  journal = {Functional Ecology},
  volume = {33},
  number = {2},
  pages = {323--334},
  issn = {1365-2435},
  doi = {10.1111/1365-2435.13254},
  urldate = {2020-09-08},
  abstract = {Robust predictions of predator--prey interactions are fundamental for the understanding of food webs, their structure, dynamics, resistance to species loss, response to invasions and ecosystem function. Most current food web models measure parameters at the food web level to predict patterns at the same level. Thus, they are sensitive to the quality of the data and may be ineffective in predicting non-observed interactions and disturbed food webs. There is a need for mechanistic models that predict the occurrence of a predator--prey interaction based on lower levels of organization (i.e. the traits of organisms) and the properties of their environment. Here, we present such a model that focuses on the predation act itself. We built a Newtonian, mechanical model for the processes of searching, capturing and handling of a prey item by a predator. Associated with general metabolic laws, we predict the net energy gain from predation for pairs of pelagic or flying predator species and their prey depending on their body sizes. Predicted interactions match well with data from the most extensive predator--prey database, and overall model accuracy is greater than the allometric niche model. Our model shows that it is possible to accurately predict the structure of food webs using only a few mechanical traits. It underlines the importance of physical constraints in structuring food webs. A plain language summary is available for this article.},
  copyright = {{\copyright} 2018 The Authors. Functional Ecology {\copyright} 2018 British Ecological Society},
  langid = {english},
  keywords = {body size,energy,mechanics,predation,trophic link},
  file = {/Users/benobo/Zotero/storage/M7KUK962/Portalier et al. - 2019 - The mechanics of predator–prey interactions First.pdf;/Users/benobo/Zotero/storage/3VY2HPIY/1365-2435.html}
}

@article{Preston2018WhaDri,
  title = {What Drives Interaction Strengths in Complex Food Webs? {{A}} Test with Feeding Rates of a Generalist Stream Predator},
  shorttitle = {What Drives Interaction Strengths in Complex Food Webs?},
  author = {Preston, Daniel L. and Henderson, Jeremy S. and Falke, Landon P. and Segui, Leah M. and Layden, Tamara J. and Novak, Mark},
  year = {2018},
  journal = {Ecology},
  volume = {99},
  number = {7},
  pages = {1591--1601},
  issn = {1939-9170},
  doi = {10.1002/ecy.2387},
  urldate = {2023-07-19},
  abstract = {Describing the mechanisms that drive variation in species interaction strengths is central to understanding, predicting, and managing community dynamics. Multiple factors have been linked to trophic interaction strength variation, including species densities, species traits, and abiotic factors. Yet most empirical tests of the relative roles of multiple mechanisms that drive variation have been limited to simplified experiments that may diverge from the dynamics of natural food webs. Here, we used a field-based observational approach to quantify the roles of prey density, predator density, predator-prey body-mass ratios, prey identity, and abiotic factors in driving variation in feeding rates of reticulate sculpin (Cottus perplexus). We combined data on over 6,000 predator-prey observations with prey identification time functions to estimate 289 prey-specific feeding rates at nine stream sites in Oregon. Feeding rates on 57 prey types showed an approximately log-normal distribution, with few strong and many weak interactions. Model selection indicated that prey density, followed by prey identity, were the two most important predictors of prey-specific sculpin feeding rates. Feeding rates showed a positive relationship with prey taxon densities that was inconsistent with predator saturation predicted by current functional response models. Feeding rates also exhibited four orders-of-magnitude in variation across prey taxonomic orders, with the lowest feeding rates observed on prey with significant anti-predator defenses. Body-mass ratios were the third most important predictor variable, showing a hump-shaped relationship with the highest feeding rates at intermediate ratios. Sculpin density was negatively correlated with feeding rates, consistent with the presence of intraspecific predator interference. Our results highlight how multiple co-occurring drivers shape trophic interactions in nature and underscore ways in which simplified experiments or reliance on scaling laws alone may lead to biased inferences about the structure and dynamics of species-rich food webs.},
  langid = {english},
  keywords = {body size,feeding rate,food web,functional response,predation,predator-prey,species interaction strength,trophic dynamics},
  file = {/Users/benobo/Zotero/storage/7XRR9A75/Preston et al. - 2018 - What drives interaction strengths in complex food .pdf;/Users/benobo/Zotero/storage/RSC8EN4E/ecy.html}
}

@article{Rall2012UniTem,
  title = {Universal Temperature and Body-Mass Scaling of Feeding Rates},
  author = {Rall, Bj{\"o}rn C. and Brose, Ulrich and Hartvig, Martin and Kalinkat, Gregor and Schwarzm{\"u}ller, Florian and {Vucic-Pestic}, Olivera and Petchey, Owen L.},
  year = {2012},
  month = nov,
  journal = {Philosophical Transactions of the Royal Society B: Biological Sciences},
  volume = {367},
  number = {1605},
  pages = {2923--2934},
  publisher = {Royal Society},
  doi = {10.1098/rstb.2012.0242},
  urldate = {2024-05-12},
  abstract = {Knowledge of feeding rates is the basis to understand interaction strength and subsequently the stability of ecosystems and biodiversity. Feeding rates, as all biological rates, depend on consumer and resource body masses and environmental temperature. Despite five decades of research on functional responses as quantitative models of feeding rates, a unifying framework of how they scale with body masses and temperature is still lacking. This is perplexing, considering that the strength of functional responses (i.e. interaction strengths) is crucially important for the stability of simple consumer--resource systems and the persistence, sustainability and biodiversity of complex communities. Here, we present the largest currently available database on functional response parameters and their scaling with body mass and temperature. Moreover, these data are integrated across ecosystems and metabolic types of species. Surprisingly, we found general temperature dependencies that differed from the Arrhenius terms predicted by metabolic models. Additionally, the body-mass-scaling relationships were more complex than expected and differed across ecosystems and metabolic types. At local scales (taxonomically narrow groups of consumer--resource pairs), we found hump-shaped deviations from the temperature and body-mass-scaling relationships. Despite the complexity of our results, these body-mass- and temperature-scaling models remain useful as a mechanistic basis for predicting the consequences of warming for interaction strengths, population dynamics and network stability across communities differing in their size structure.},
  keywords = {allometric scaling,body size,functional response,interaction strength,metabolic theory,warming},
  file = {/Users/benobo/Zotero/storage/F8CRQ6M9/Rall et al. - 2012 - Universal temperature and body-mass scaling of fee.pdf}
}

